# ══════════════════════════════════════════════
# TabulateAI — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env.local for development.
# For Railway production: set these in the Railway dashboard.
#
# Legend:
#   [REQUIRED]  — App will not start without this
#   [REQUIRED*] — Required in production, optional in dev (has dev fallback)
#   [OPTIONAL]  — Has sensible default

# ──────────────────────────────────────────────
# Azure OpenAI [OPTIONAL — not currently in active use]
# ──────────────────────────────────────────────
# Dormant provider — code supports it but no active deployment.
# Only set these if you want to use Azure OpenAI as a model provider.
# AZURE_API_KEY=
# AZURE_RESOURCE_NAME=
# AZURE_API_VERSION=2025-01-01-preview

# ──────────────────────────────────────────────
# Convex — Real-time database [REQUIRED]
# ──────────────────────────────────────────────
# Development: run `npx convex dev` to create project + deployment
# Production: create a separate deployment in Convex Dashboard
# Dashboard: https://dashboard.convex.dev
CONVEX_URL=
NEXT_PUBLIC_CONVEX_URL=
# Deploy key for server-side internalMutation access (all mutations require this)
# Get from: Convex Dashboard → Settings → Deploy Keys
CONVEX_DEPLOY_KEY=

# ──────────────────────────────────────────────
# Cloudflare R2 — File storage [REQUIRED]
# ──────────────────────────────────────────────
# Create bucket in Cloudflare Dashboard > R2 > Create Bucket
# Create API token with Object Read & Write permission
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tabulate-ai-dev

# ──────────────────────────────────────────────
# WorkOS — Authentication [REQUIRED*]
# ──────────────────────────────────────────────
# Create account at https://workos.com
# In production: set redirect URI to your production domain
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=
# Development: http://localhost:3000/auth/callback
# Production: https://your-domain.com/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Auth Bypass — DEVELOPMENT ONLY
# Set to 'true' to skip WorkOS login (uses hardcoded dev user)
# WARNING: Throws an error if enabled with NODE_ENV=production
AUTH_BYPASS=true

# ──────────────────────────────────────────────
# Sentry — Error tracking [REQUIRED*]
# ──────────────────────────────────────────────
# DSN from Sentry project settings
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map upload during build (CI/CD only)
# SENTRY_AUTH_TOKEN=

# ──────────────────────────────────────────────
# Stripe — Payment Processing [REQUIRED*]
# ──────────────────────────────────────────────
# Create account at https://stripe.com
# Keys from: Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from: Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=

# Meter ID (from Stripe Dashboard → Meters)
# One meter for project usage across all tiers
STRIPE_METER_ID=

# Price IDs (from Stripe Dashboard → Products)
# Each plan has a recurring monthly price + a graduated metered price
STRIPE_PRICE_PAYG=
STRIPE_PRICE_PAYG_METERED=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STARTER_METERED=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_PROFESSIONAL_METERED=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_STUDIO_METERED=

# ──────────────────────────────────────────────
# Resend — Email Notifications [REQUIRED*]
# ──────────────────────────────────────────────
# Create account at https://resend.com, verify your domain
# API key from: Dashboard → API Keys
RESEND_API_KEY=
# From address must use your verified domain
# Default: TabulateAI <notifications@tabulate-ai.com>
RESEND_FROM_ADDRESS=

# ──────────────────────────────────────────────
# Model Configuration [OPTIONAL]
# ──────────────────────────────────────────────
# Azure deployment names (not OpenAI model names).
# All have sensible defaults — only override if you need a different model.

# CrosstabAgentV2: Question-centric crosstab planning (V3 stage 21)
# CROSSTAB_MODEL=o4-mini
# CROSSTAB_MODEL_TOKENS=100000
# CROSSTAB_REASONING_EFFORT=medium
# CROSSTAB_PROMPT_VERSION=production_v3

# BannerAgent: Banner extraction from PDF/DOCX (V3 stage 20)
# BANNER_MODEL=gpt-5-nano
# BANNER_MODEL_TOKENS=128000
# BANNER_REASONING_EFFORT=medium
# BANNER_PROMPT_VERSION=production

# BannerGenerateAgent: Banner generation from data (V3 stage 20/21)
# BANNER_GENERATE_MODEL=gpt-5-mini
# BANNER_GENERATE_MODEL_TOKENS=128000
# BANNER_GENERATE_REASONING_EFFORT=high
# BANNER_GENERATE_PROMPT_VERSION=production

# LoopSemanticsPolicyAgent: Loop anchoring policy (V3 post-join)
# LOOP_SEMANTICS_MODEL=gpt-5-mini
# LOOP_SEMANTICS_MODEL_TOKENS=128000
# LOOP_SEMANTICS_REASONING_EFFORT=medium
# LOOP_SEMANTICS_PROMPT_VERSION=production

# AIGateAgent: Triage + validation gate (V3 stages 10/11)
# AIGATE_MODEL=gpt-5-mini
# AIGATE_MODEL_TOKENS=128000
# AIGATE_REASONING_EFFORT=medium
# AIGATE_PROMPT_VERSION=production

# LoopGateAgent: Binary loop classification (V3 stage 10a)
# LOOP_GATE_MODEL=gpt-5-mini
# LOOP_GATE_MODEL_TOKENS=128000
# LOOP_GATE_REASONING_EFFORT=medium
# LOOP_GATE_PROMPT_VERSION=production

# SubtypeGateAgent: Subtype confirmation (V3 stage 13c1)
# SUBTYPE_GATE_MODEL=gpt-5-mini
# SUBTYPE_GATE_MODEL_TOKENS=128000
# SUBTYPE_GATE_REASONING_EFFORT=medium
# SUBTYPE_GATE_PROMPT_VERSION=production

# StructureGateAgent: Structure review (V3 stage 13c2)
# STRUCTURE_GATE_MODEL=gpt-5-mini
# STRUCTURE_GATE_MODEL_TOKENS=128000
# STRUCTURE_GATE_REASONING_EFFORT=medium
# STRUCTURE_GATE_PROMPT_VERSION=production

# SurveyCleanupAgent: Survey parse cleanup (V3 stage 08b)
# SURVEY_CLEANUP_MODEL=gpt-5-mini
# SURVEY_CLEANUP_MODEL_TOKENS=128000
# SURVEY_CLEANUP_REASONING_EFFORT=medium
# SURVEY_CLEANUP_PROMPT_VERSION=production

# TableContextAgent: Table context review (V3 stage 13e)
# TABLE_CONTEXT_MODEL=gpt-5-mini
# TABLE_CONTEXT_MODEL_TOKENS=128000
# TABLE_CONTEXT_REASONING_EFFORT=medium
# TABLE_CONTEXT_PROMPT_VERSION=production

# NETEnrichmentAgent: NET enrichment proposal (V3 stage 13e)
# NET_ENRICHMENT_MODEL=gpt-5-mini
# NET_ENRICHMENT_MODEL_TOKENS=128000
# NET_ENRICHMENT_REASONING_EFFORT=medium
# NET_ENRICHMENT_PROMPT_VERSION=production

# ──────────────────────────────────────────────
# Pipeline Settings [OPTIONAL]
# ──────────────────────────────────────────────
# MAX_DATA_MAP_VARIABLES=1000
# MAX_BANNER_COLUMNS=100
# TRACING_ENABLED=true
# DATAMAP_FORMAT=raw
# Generation Sampling (output consistency)
# temperature: 0-2 (0 = deterministic). Reasoning models ignore this internally.
# seed: integer for reproducible outputs (primary lever for consistency).
# parallelToolCalls: false = sequential tool calls for determinism.
# GENERATION_TEMPERATURE=0
# GENERATION_SEED=42
# GENERATION_PARALLEL_TOOL_CALLS=false

# ──────────────────────────────────────────────
# Application [OPTIONAL]
# ──────────────────────────────────────────────
# NODE_ENV=development
# EXPOSE_API_ERROR_DETAILS=false
# Set to 'true' on staging if you want the project detail page to show the
# canonical R2 run prefix (orgId/projectId/runs/runId) for copy/paste debugging.
# NEXT_PUBLIC_ENABLE_R2_ARTIFACT_DEBUG_PATH=false

# Legacy session-based routes (/api/process-crosstab, /api/generate-tables,
# /api/execute-r, /api/export-workbook, /api/loop-detect) are disabled by
# default. Set to 'true' only if you need them for backward-compatible testing.
# ENABLE_LEGACY_SESSION_ROUTES=false

# ──────────────────────────────────────────────
# Decipher API (not yet in production use)
# ──────────────────────────────────────────────
# DECIPHER_API_KEY=
# DECIPHER_BASE_URL=https://selfserve.decipherinc.com
# DECIPHER_SURVEY_PATH=
